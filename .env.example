# Copy this file to `.env` and fill in real values. NEVER commit `.env`.
QUANT_ENV=dev

# Postgres / TimescaleDB
QUANT_DB_DSN=postgresql://quant:quant@localhost:5432/quant

# Redis (online feature store cache)
REDIS_URL=redis://localhost:6379/0

# MinIO (S3-compatible object store for raw lake + MLflow artifacts)
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minio
MINIO_SECRET_KEY=minio123
RAW_LAKE_BUCKET=quant-raw

# Qdrant (vector DB for NLP embeddings)
QDRANT_URL=http://localhost:6333

# MLflow
MLFLOW_TRACKING_URI=http://localhost:5000
WANDB_API_KEY=

# --- Data vendor credentials (NSE is anti-bot; a paid vendor is required) ---
# Provider name must match configs/data/*.yaml -> data.nse.provider
# For dev/tests keep provider=mock (no creds needed).
NSE_PROVIDER=mock
# Example real provider (do NOT commit the token):
# NSE_TRUEDATA_TOKEN=
# NSE_EODHISTORICAL_TOKEN=
